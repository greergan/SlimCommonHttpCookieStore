#ifndef SLIM_COMMON_HTTP_COOKIE_STORE_H
#define SLIM_COMMON_HTTP_COOKIE_STORE_H

#include <exception>
#include <cctype>
#include <memory>
#include <string>
#include <string_view>
#include <vector>

#include <slim/common/http/cookie.h>
#include <slim/common/http/error_codes.h>

#define SLIMCOMMONHTTPCOOKIESTORE_VERSION  "@SLIMCOMMONHTTPCOOKIESTORE_VERSION@"
#define SLIMCOMMONHTTPCOOKIESTORE_GIT_HASH "@SLIMCOMMONHTTPCOOKIESTORE_GIT_HASH@"

namespace slim::common::http {

class CookieStore {
public:
    const std::vector<std::shared_ptr<Cookie>>& entries() const { return store; }
    void erase(std::string_view name, std::string_view domain, std::string_view path) noexcept;
    std::shared_ptr<Cookie> get(std::string_view name, std::string_view domain = {}, std::string_view path = {}) const noexcept;
    ErrorStatus set(std::string_view string) noexcept;
    ErrorStatus set(std::string_view name, std::string_view value) noexcept;
    ErrorStatus set(Cookie&& cookie) noexcept;
    ErrorStatus set(std::shared_ptr<Cookie> cookie) noexcept;
    ErrorStatus set_cookies(std::string_view string) noexcept;
    std::string serialize() const;

private:
    std::vector<std::shared_ptr<Cookie>> store{};
};

} // namespace slim::common::http

#endif // SLIM_COMMON_HTTP_COOKIE_STORE_H
