#ifndef SLIM_COMMON_HTTP_COOKIE_STORE_H
#define SLIM_COMMON_HTTP_COOKIE_STORE_H

#include <cctype>
#include <chrono>
#include <memory>
#include <optional>
#include <string>
#include <string_view>
#include <unordered_map>
#include <vector>
#include <slim/SlimValue.hpp>

#define SLIMCOMMONHTTPCOOKIESTORE_VERSION  "@SLIMCOMMONHTTPCOOKIESTORE_VERSION@"
#define SLIMCOMMONHTTPCOOKIESTORE_GIT_HASH "@SLIMCOMMONHTTPCOOKIESTORE_GIT_HASH@"

namespace slim::common::http {

struct Cookie {
    std::string domain;
    std::string expires;
    std::string max_age;
    std::string name;
    std::string path;
    std::string same_site; // strict, lax or none
    std::string value;
    bool        httponly = false;
    bool        partitioned = false;
    bool        secure = false;
};

class CookieStore {
public:
    const std::vector<std::shared_ptr<Cookie>>& entries() const { return store; }
    void erase(std::string_view name, std::string_view domain = {}, std::string_view path = {});
    const std::string get(std::string_view name) const;
    slim::SlimValue set(Cookie&& cookie, const bool validate_expiry = true);
    slim::SlimValue set(std::string_view string);
    slim::SlimValue set_cookies(std::string_view string);
    slim::SlimValue set(std::string_view name, std::string_view value);
    std::string serialize();
    std::string serialize_headers();

private:
    std::vector<std::shared_ptr<Cookie>> store;
};

} // slim::common::http
#endif // SLIM_COMMON_HTTP_COOKIE_STORE_H
